              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Doğrulanmış kullanıcının kendi kimliği",
        "tags": ["auth"]
      }
    },
    "/v1/profile": {
      "get": {
        "operationId": "ProfileController_get",
