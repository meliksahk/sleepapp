  "info": {
    "title": "NOCTA API",
    "description": "Sleep Identity Platform — v1",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDeviceDto": {
        "type": "object",
        "properties": {
          "fingerprint": {
            "type": "string",
            "description": "Cihaz başına benzersiz parmak izi",
            "example": "abc123-device"
          },
          "platform": {
            "type": "string",
            "enum": ["ios", "android", "web"],
            "example": "ios"
          }
        },
        "required": ["fingerprint", "platform"]
      },
      "SessionResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "accessTokenExpiresIn": {
            "type": "number",
            "description": "Access token ömrü (saniye)",
            "example": 900
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": ["accessToken", "refreshToken", "accessTokenExpiresIn", "userId"]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Opak refresh token"
          }
        },
        "required": ["refreshToken"]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["userId", "roles"]
      },
      "RequestEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          }
        },
        "required": ["email"]
      },
      "EmailRequestResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "sent"
          },
          "devMagicToken": {
            "type": "string",
            "description": "Yalnızca development — test için ham token"
          }
        },
        "required": ["status"]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Magic link token"
          }
        },
        "required": ["token"]
      },
      "EmailVerifyResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": ["userId", "email"]
      },
      "ProfileResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "object",
            "nullable": true
          },
          "chronotype": {
            "type": "object",
            "nullable": true
          },
          "locale": {
            "type": "string",
            "example": "en"
          },
          "timezone": {
            "type": "string",
            "example": "UTC"
          }
        },
        "required": ["userId", "displayName", "chronotype", "locale", "timezone"]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "object",
            "maxLength": 40,
            "nullable": true
          },
          "chronotype": {
            "type": "string",
            "enum": ["lion", "bear", "wolf", "dolphin"],
            "nullable": true
          },
          "locale": {
            "type": "string",
            "example": "en",
            "maxLength": 10
          },
          "timezone": {
            "type": "string",
            "example": "Europe/Istanbul",
            "maxLength": 64
          }
        }
      },
      "QuestionOptionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "archetype": {
            "type": "string",
            "enum": ["deep-ocean", "overthinker", "delta-drifter", "dawn-chaser"]
          }
        },
        "required": ["id", "label", "archetype"]
      },
      "QuestionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionOptionDto"
            }
          }
        },
        "required": ["id", "prompt", "options"]
      },
      "QuestionsResponseDto": {
        "type": "object",
        "properties": {
          "version": {
            "type": "number",
            "example": 1
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionDto"
            }
          }
        },
        "required": ["version", "questions"]
      },
      "SubmitAnswersDto": {
        "type": "object",
        "properties": {
          "version": {
            "type": "number",
            "description": "Soru matrisi sürümü",
            "example": 1
          },
          "answers": {
            "type": "object",
            "description": "questionId → optionId eşlemesi",
            "example": {
              "q1": "q1a",
              "q2": "q2b"
            },
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": ["version", "answers"]
      },
      "ArchetypeResultResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "archetypeSlug": {
            "type": "string",
            "enum": ["deep-ocean", "overthinker", "delta-drifter", "dawn-chaser"]
          },
          "scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "version": {
            "type": "number",
            "example": 1
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["userId", "archetypeSlug", "scores", "version", "createdAt"]
      },
      "WebResultResponseDto": {
        "type": "object",
        "properties": {
          "shareSlug": {
            "type": "string",
            "description": "Paylasim slug (/a/{...})"
          },
          "archetypeSlug": {
            "type": "string",
            "enum": ["deep-ocean", "overthinker", "delta-drifter", "dawn-chaser"]
          },
          "scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "version": {
            "type": "number",
            "example": 1
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": ["shareSlug", "archetypeSlug", "scores", "version", "createdAt"]
      },
      "SoundscapeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "titleI18n": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "engineParams": {
            "type": "object",
            "additionalProperties": true
          },
          "layerDefs": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          },
          "archetypeAffinity": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "version": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "id",
          "slug",
          "titleI18n",
          "engineParams",
          "layerDefs",
          "archetypeAffinity",
          "version"
        ]
      },
      "PresetDto": {
        "type": "object",
        "properties": {
          "archetypeSlug": {
            "type": "string"
          },
          "mixerState": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        },
        "required": ["archetypeSlug", "mixerState"]
      },
      "SoundscapeDetailDto": {
        "type": "object",
        "properties": {
          "soundscape": {
            "$ref": "#/components/schemas/SoundscapeDto"
          },
          "presets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PresetDto"
            }
          },
          "previewUrl": {
            "type": "object",
            "nullable": true,
            "description": "Presigned önizleme URL (varsa)"
          }
        },
        "required": ["soundscape", "presets", "previewUrl"]
      },
      "JoinWaitlistDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "source": {
            "type": "string",
            "example": "tiktok",
            "description": "UTM/kaynak etiketi"
          }
        },
        "required": ["email"]
      }
    }
  }
}
