            }
          }
        },
        "summary": "Anonim web testi — skorla + paylaşım slug üret",
        "tags": ["archetype-web"]
      }
    },
    "/v1/archetype/web/{slug}": {
      "get": {
        "operationId": "WebArchetypeController_result",
        "parameters": [
          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
