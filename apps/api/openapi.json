{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_health",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["health"]
      }
    },
    "/v1/auth/device": {
      "post": {
        "operationId": "AuthController_device",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDeviceDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponseDto"
                }
              }
            }
          }
        },
        "summary": "Anonim cihaz kaydı → access + refresh token",
        "tags": ["auth"]
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Geçersiz veya yeniden kullanılmış refresh token"
          }
        },
        "summary": "Refresh token rotasyonu (reuse-detection ile)",
        "tags": ["auth"]
      }
    },
    "/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Doğrulanmış kullanıcının kendi kimliği",
        "tags": ["auth"]
      }
    }
  },
  "info": {
    "title": "NOCTA API",
    "description": "Sleep Identity Platform — v1",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDeviceDto": {
        "type": "object",
        "properties": {
          "fingerprint": {
            "type": "string",
            "description": "Cihaz başına benzersiz parmak izi",
            "example": "abc123-device"
          },
          "platform": {
            "type": "string",
            "enum": ["ios", "android", "web"],
            "example": "ios"
          }
        },
        "required": ["fingerprint", "platform"]
      },
      "SessionResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "accessTokenExpiresIn": {
            "type": "number",
            "description": "Access token ömrü (saniye)",
            "example": 900
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": ["accessToken", "refreshToken", "accessTokenExpiresIn", "userId"]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Opak refresh token"
          }
        },
        "required": ["refreshToken"]
      },
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["userId", "roles"]
      }
    }
  }
}
