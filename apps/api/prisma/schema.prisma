generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model auth_devices {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @db.Uuid
  device_fingerprint String   @unique
  platform           String
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_auth_devices_user")
}

model one_time_tokens {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String      @db.Uuid
  purpose    ott_purpose
  token_hash String      @unique
  expires_at DateTime    @db.Timestamptz(6)
  used_at    DateTime?   @db.Timestamptz(6)
  users      users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_ott_user")
}

model profiles {
  id           String   @id @db.Uuid
  display_name String?
  chronotype   String?
  locale       String   @default("en")
  timezone     String   @default("UTC")
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  family_id  String    @db.Uuid
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([family_id], map: "idx_refresh_tokens_family")
  @@index([user_id], map: "idx_refresh_tokens_user")
}

model schema_migrations {
  version String @id @db.VarChar
}

model users {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind              user_kind           @default(anonymous)
  email             String?             @unique
  email_verified_at DateTime?           @db.Timestamptz(6)
  password_hash     String?
  totp_secret       String?
  roles             String[]            @default([])
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?           @db.Timestamptz(6)
  archetype_results archetype_results[]
  auth_devices      auth_devices[]
  one_time_tokens   one_time_tokens[]
  profiles          profiles?
  refresh_tokens    refresh_tokens[]
}

model archetype_results {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  archetype_slug String
  answers        Json
  scores         Json
  version        Int
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "idx_archetype_results_user")
}

model web_archetype_results {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  share_slug     String   @unique
  archetype_slug String
  scores         Json
  version        Int
  created_at     DateTime @default(now()) @db.Timestamptz(6)
}

model feature_flags {
  key         String   @id
  description String?
  rules       Json     @default("{\"enabled\": false}")
  updated_by  String?  @db.Uuid
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

model presets {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  soundscape_id  String      @db.Uuid
  archetype_slug String
  mixer_state    Json
  soundscapes    soundscapes @relation(fields: [soundscape_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([soundscape_id], map: "idx_presets_soundscape")
}

model soundscapes {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String         @unique
  title_i18n         Json
  engine_params      Json
  layer_defs         Json
  archetype_affinity String[]       @default([])
  status             content_status @default(draft)
  publish_at         DateTime?      @db.Timestamptz(6)
  created_by         String?        @db.Uuid
  version            Int            @default(1)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  presets            presets[]

  @@index([status], map: "idx_soundscapes_status")
}

enum ott_purpose {
  magic_link
  email_verify
  password_reset
}

enum user_kind {
  anonymous
  registered
  admin
}

enum content_status {
  draft
  scheduled
  published
}
