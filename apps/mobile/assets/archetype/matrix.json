    "en": {
      "questions": {
        "q1": {
          "prompt": "When your head hits the pillow, your mind…",
          "options": {
            "q1a": "sinks into stillness",
            "q1b": "replays the whole day",
            "q1c": "drifts somewhere far away",
            "q1d": "is already planning tomorrow"
          }
        },
        "q2": {
          "prompt": "Your ideal bedroom sound is…",
          "options": {
            "q2a": "deep ocean hush",
            "q2b": "soft rain to quiet my thoughts",
            "q2c": "slow ambient waves",
            "q2d": "nothing — I wake with the sun"
          }
        },
        "q3": {
          "prompt": "You wake at 3am. You…",
          "options": {
            "q3a": "roll over, gone again",
            "q3b": "start a mental to-do list",
            "q3c": "float in a half-dream",
            "q3d": "check if it is nearly morning"
          }
        },
        "q4": {
          "prompt": "Mornings feel best when…",
          "options": {
            "q4a": "I slept like a stone",
            "q4b": "my head finally went quiet",
            "q4c": "I remember a vivid dream",
            "q4d": "the first light wakes me gently"
          }
        },
        "q5": {
          "prompt": "Your relationship with your alarm is…",
          "options": {
            "q5a": "I rarely need it",
            "q5b": "I beat it, lying awake",
            "q5c": "it pulls me from deep sleep",
            "q5d": "I am up before it rings"
          }
        },
        "q6": {
          "prompt": "A perfect night is…",
          "options": {
            "q6a": "deep and dreamless",
            "q6b": "finally switching off",
            "q6c": "long, drifting, surreal",
            "q6d": "early to bed, early to rise"
          }
        }
