<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ yedek/aktarım kuralları. Gerekçe için bkz. backup_rules.xml —
  ikisi birlikte gerekli, çünkü minSdk 24.

  `cloud-backup` ve `device-transfer` AYRI AYRI yazılır: birini yazıp diğerini
  atlamak, dosyaların bulut yedeğinden çıkıp cihaz-cihaz aktarımında yine
  taşınması demek olurdu.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="nocta_sounds" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="nocta_sounds" />
    </device-transfer>
</data-extraction-rules>
