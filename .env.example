# NOCTA — ortam değişkeni örnekleri. Gerçek .env ASLA commit edilmez (CLAUDE.md §6).
# Kopyala: cp .env.example .env
#
# API değişkenleri `apps/api/src/shared/config/env.ts`'deki zod şemasıyla senkrondur
# ve `pnpm check:env-example` bunu CI'da ZORLAR: şemaya yeni değişken eklenip buraya
# eklenmezse kapı düşer. (Bu dosya bir kez bayatladı — 23 değişkenin 11'i eksikti.)

# --- Postgres (lokal docker compose) ---
POSTGRES_USER=nocta
POSTGRES_PASSWORD=nocta_local_dev
POSTGRES_DB=nocta
POSTGRES_PORT=5432

# dbmate / API bağlantı stringi (lokal)
DATABASE_URL=postgres://nocta:nocta_local_dev@localhost:5432/nocta?sslmode=disable

# --- Redis (lokal) ---
REDIS_URL=redis://localhost:6379

# --- MinIO (lokal S3) ---
MINIO_ROOT_USER=nocta
MINIO_ROOT_PASSWORD=nocta_local_dev
MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1
MINIO_BUCKET_SOUNDSCAPES=soundscape-assets
# Ses DOSYALARI (audio_assets tablosu). Soundscape önizlemelerinden ayrı bucket.
# `node tooling/upload-audio-assets.mjs` bu bucket'a yükler, yoksa oluşturur.
MINIO_BUCKET_AUDIO_ASSETS=audio-assets

# --- API ---
API_PORT=3001
NODE_ENV=development
# identity: JWT RS256 anahtar çifti (PEM). Üretimde GitHub Environments/VPS env'de tutulur.
# Lokal geliştirme için `pnpm --filter api keys:gen` üretir (repoya girmez).
# BOŞ bırakılırsa development'ta ephemeral üretilir; production'da boot FAIL eder.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Magic link (e-posta ile hesap yükseltme)
MAGIC_LINK_TTL=900
MAGIC_LINK_BASE_URL=http://localhost:3003/auth/verify

# Paylaşım — derin link + web kart URL'leri (viral kancalar).
WEB_BASE_URL=https://nocta.app
APP_DEEPLINK_SCHEME=nocta

# İstek gövdesi boyut limiti (DoS sertleşme). 64kb — payload'larımız küçük.
MAX_REQUEST_BODY_BYTES=65536

# Tarayıcıdan API'ye erişebilecek kaynaklar (virgülle ayrık). Tanıtım sitesi public
# uçları TARAYICIDAN çağırır (/v1/archetype/web/questions, /v1/waitlist); bu liste
# olmadan tarayıcı isteği ERR_FAILED alır. JOKER (*) KULLANILMAZ: kimlik bilgisi
# taşıyan istekleri imkânsız kılar ve API'yi her siteye açardı.
# Üretimde gerçek alan adları: https://nocta.app,https://admin.nocta.app
CORS_ORIGINS=http://localhost:3003,http://localhost:3002

# IP rate-limit. Testte yüksek tutulur (e2e tek IP'den yüzlerce istek atar);
# üretimde sıkı olmalı. Dağıtık (Redis) storage B4'te.
THROTTLE_LIMIT=60
THROTTLE_TTL_MS=60000

# Admin girişi için AYRI ve çok daha sıkı limit (dakikada 5 deneme). Global 60/dk
# "gezinme" için makul, "parola tahmini" için değil. YÜKSELTMEK kaba kuvvet kapısını
# açar — bilinçli yapılsın.
ADMIN_LOGIN_LIMIT=5

# Rotasyondan sonra aynı refresh token'ın "yarış" sayıldığı pencere (ms). İki sekme
# aynı anda yenilerse kullanıcıyı atmamak için. 0 = katı davranış; büyütmek çalıntı
# token'ın yakalanmadığı pencereyi büyütür.
REFRESH_REUSE_GRACE_MS=10000

# --- Sentry (opsiyonel; boşsa devre dışı) ---
SENTRY_DSN=

# --- apps/admin (panel) ---
# API tabanı. NEXT_PUBLIC_ DEĞİL, bilinçli: panelin tarayıcı tarafı API'ye doğrudan
# gitmez; token httpOnly çerezde kalsın diye çağrılar sunucudan geçer.
API_URL=http://localhost:3001

# --- apps/web (tanıtım sitesi) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3003
